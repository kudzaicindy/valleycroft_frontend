# Valley Croft Farm Management System
# Copy to .env and set values. Never commit .env.

# Frontend: optional override for API base URL (always wins when set).
# Leave unset for smart defaults: npm run dev and http://localhost → http://localhost:5000;
# production deploys → https://valleycroft-backend.onrender.com unless you set this.
# VITE_API_URL=https://your-api.example.com

# Dev proxy target (npm run dev only): where Vite forwards /api. Defaults to http://localhost:5000
# VITE_API_PROXY_TARGET=http://localhost:3001

# Used when opening a production build on localhost (e.g. vite preview), if VITE_API_URL is unset:
# VITE_API_URL_LOCAL=http://localhost:5000

# ---------------------------------------------------------------------------
# Backend (.env) — set on the API server for CORS
# ---------------------------------------------------------------------------
# Allow frontend origin(s). Comma-separated for multiple.
# Local (Vite default port):  FRONTEND_URL=http://localhost:5173
# If frontend runs on 3000:   FRONTEND_URL=http://localhost:3000
# Dev + production:            FRONTEND_URL=http://localhost:5173,https://your-app.com
# FRONTEND_URL=http://localhost:5173

# ---------------------------------------------------------------------------
# Seeded users (after running seed on backend: npm run seed:users)
# ---------------------------------------------------------------------------
# CEO      | ceo@valleyroad.com     | ceo123456
# Admin    | admin@valleyroad.com   | admin123456
# Finance  | finance@valleyroad.com | finance123456
# Employee | employee@valleyroad.com| employee123456
# Change passwords after first login (PUT /api/auth/change-password).
